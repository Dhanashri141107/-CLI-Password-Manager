import json, os, getpass, base64
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
from cryptography.hazmat.primitives.ciphers.aead import AESGCM

VAULT_FILE = "vault.json"

# Derive a strong key from master password
def derive_key(password: str, salt: bytes) -> bytes:
    kdf = PBKDF2HMAC(
        algorithm=hashes.SHA256(),
        length=32,
        salt=salt,
        iterations=480000
    )
    return kdf.derive(password.encode())

# Encrypt data using AES-GCM
def encrypt_data(key: bytes, data: dict) -> dict:
    aesgcm = AESGCM(key)
    nonce = os.urandom(12)
    plaintext = json.dumps(data).encode()
    ciphertext = aesgcm.encrypt(nonce, plaintext, None)
    return {
        "nonce": base64.b64encode(nonce).decode(),
        "ciphertext": base64.b64encode(ciphertext).decode()
    }

# Decrypt data
def decrypt_data(key: bytes, enc: dict) -> dict:
    aesgcm = AESGCM(key)
    nonce = base64.b64decode(enc["nonce"])
    ciphertext = base64.b64decode(enc["ciphertext"])
    plaintext = aesgcm.decrypt(nonce, ciphertext, None)
    return json.loads(plaintext.decode())

# Load or initialize vault
def load_vault(master_password: str):
    try:
        with open(VAULT_FILE, "r") as f:
            vault = json.load(f)
            salt = base64.b64decode(vault["salt"])
    except (FileNotFoundError, json.JSONDecodeError):
        salt = os.urandom(16)
        vault = {"salt": base64.b64encode(salt).decode(), "entries": {}}
    key = derive_key(master_password, salt)
    return vault, key

# Add new entry
def add_entry(master_password: str):
    website = input("Website: ")
    username = input("Username: ")
    password = getpass.getpass("Password: ")

    vault, key = load_vault(master_password)

    entry = {"username": username, "password": password}
    encrypted_entry = encrypt_data(key, entry)
    vault["entries"][website] = encrypted_entry

    with open(VAULT_FILE, "w") as f:
        json.dump(vault, f)

    print(f"✅ Entry for {website} added securely!")

# Retrieve entry
def get_entry(master_password: str):
    website = input("Website: ")
    vault, key = load_vault(master_password)

    if website not in vault["entries"]:
        print("❌ No entry found.")
        return

    enc = vault["entries"][website]
    entry = decrypt_data(key, enc)
    print(f"🔑 {website} → Username: {entry['username']}, Password: {entry['password']}")

# Main interactive loop
if __name__ == "__main__":
    master_password = getpass.getpass("Master Password: ")
    action = input("Choose action (add/get): ").strip().lower()

    if action == "add":
        add_entry(master_password)
    elif action == "get":
        get_entry(master_password)
    else:
        print("❌ Invalid action. Use 'add' or 'get'.")